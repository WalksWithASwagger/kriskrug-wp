# Agent-readable contract: see repo-root .env.schema (Varlock).
# Preferred: vault + `varlock run` / Cursor Cloud secrets.
# See docs/current-state/VARLOCK-ROLLOUT-2026-07-16.md
#
# This file is a COMPATIBILITY TEMPLATE for scripts/notion-to-wp/.env only.
# That .env is a temporary cache — not the source of truth. Prefer:
#   make varlock-run CMD='…'
#   or process env / .env.local with op(op://kk-dev/...)
#
# Copy to .env (gitignored) only when a tool cannot read process env.

# 1. NOTION_TOKEN — optional if you only run WP-side scripts.
#    Sibling-path fallback (KKAI_ENV_PATH / ~/Code/notion-local/...) is DEPRECATED
#    as secret SoT; still works for compat if the file exists.
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. WordPress credentials for kriskrug.co
#    Generate at: https://kriskrug.co/wp-admin/profile.php
#    → scroll to "Application Passwords"
#    → name "kk-notion-to-wp" → Add New Application Password
#    → copy the generated password (it's only shown once)
WP_USER=kk
WP_APP_PASSWORD=REPLACE_WITH_WORDPRESS_APPLICATION_PASSWORD

# 3. Optional overrides
# WP_BASE_URL=https://kriskrug.co
# WP_AUTH_MODE=basic
# Use WP_AUTH_MODE=login only when an ordinary wp-admin password is required for
# a nonce-gated REST path. Keep the password in this gitignored .env only.
# WP_DEFAULT_AUTHOR_ID=1
# WP_AUTH_MODE=login
# KKAI_ENV_PATH=/path/to/sibling/.env
# KKAI_CONTENT_ROOT=/path/to/kk-ai-ecosystem
