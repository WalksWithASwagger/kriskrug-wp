<?xml version="1.0"?>
<ruleset name="kriskrug-wp">
	<description>WordPress PHP validation for repo-owned production code.</description>

	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>
	<arg value="p"/>

	<file>inc</file>
	<file>plugins/kk-sidebar-promos</file>
	<file>theme/kk-aurora/functions.php</file>
	<file>theme/kk-aurora/patterns</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/.venv/*</exclude-pattern>
	<exclude-pattern>*/tests/smoke.php</exclude-pattern>

	<config name="testVersion" value="8.1-"/>

	<rule ref="WordPress.Security.EscapeOutput"/>
	<rule ref="WordPress.Security.NonceVerification"/>
	<rule ref="WordPress.Security.SafeRedirect"/>
	<rule ref="WordPress.Security.ValidatedSanitizedInput"/>
	<rule ref="WordPress.WP.Capabilities"/>
</ruleset>
